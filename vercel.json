{
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/dashboard", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(admin|dashboard)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ]
}
